# Copy to .env next to docker-nut-upsd.sh (or point ENV_FILE at another
# path), fill in real values, then:
#   chmod 600 .env
#
# This file contains secrets (NUT admin/monitor passwords) -- do not commit it.

CONTAINER_NAME="nut-upsd"
DOCKER_IMAGE="ghcr.io/pristavkin/nut-upsd:latest"

# Vendor/device ID for the UPS in HID mode, as shown by `lsusb`.
VENDOR_ID="051d"
DEVICE_ID="0002"

TZ="Asia/Tel_Aviv"
UPS_DESC="APC Back-UPS CS 650"

# Host port to publish upsd on (container always listens on 3493).
HOST_PORT="3493"

# NUT credentials -- generate with e.g.: openssl rand -base64 18
ADMIN_PASSWORD="change-me"
API_PASSWORD="change-me"
